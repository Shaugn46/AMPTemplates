Meta.DisplayName=Stardew Valley (Private Windows)
Meta.Description=Private AMP Generic template for JunimoServer on a Windows target node.
Meta.OS=Windows
Meta.AarchSupport=Unknown
Meta.Arch=x86_64
Meta.Author=OpenAI Codex
Meta.URL=https://github.com/stardew-valley-dedicated-server/server
Meta.DisplayImageSource=url:https://raw.githubusercontent.com/stardew-valley-dedicated-server/server/master/docs/public/logo.png
Meta.EndpointURIFormat=http://{ip}:{GenericModule.App.Ports.$ApplicationPort1}
Meta.ConfigManifest=stardew-privateconfig.json
Meta.MetaConfigManifest=
Meta.ConfigRoot=stardew-private.kvp
Meta.MinAMPVersion=2.6.0.0
Meta.SpecificDockerImage=
Meta.DockerRequired=False
Meta.DockerBaseReadOnly=False
Meta.ContainerPolicy=NotSupported
Meta.ContainerPolicyReason=This private template launches a Windows host process directly.
Meta.ExtraSetupStepsURI=
Meta.Prerequisites=[]
Meta.ExtraContainerPackages=[]
Meta.ConfigReleaseState=Private
Meta.NoCommercialUsage=False
Meta.ConfigVersion=1
Meta.ReleaseNotes=Private Windows template for JunimoServer host scripts.
Meta.BreakingReleaseNotes=
Meta.AppConfigId=2b8c8ac1-1e03-4a71-87b6-4039634ef4e2
Meta.ImportableExtensions=[]
App.DisplayName=Stardew Valley Dedicated Server
App.RootDir=./stardew-private/
App.BaseDirectory=./stardew-private/
App.SteamWorkshopDownloadLocation=
App.ExecutableWin=powershell.exe
App.ExecutableLinux=
App.WorkingDir=D:\Stardew\server
App.LinuxCommandLineArgs=
App.WindowsCommandLineArgs=
App.CommandLineArgs=-NoProfile -ExecutionPolicy Bypass -File "D:\Stardew\server\tools\amp\start-host-server-ps51.ps1" -GameDir "{{GameDir}}"
App.UseLinuxIOREDIR=False
App.AppSettings={}
App.EnvironmentVariables={"API_ENABLED":"{{APIEnabled}}","API_PORT":"{{APIPort}}","API_KEY":"{{APIKey}}","SERVER_PASSWORD":"{{ServerPassword}}","MAX_LOGIN_ATTEMPTS":"{{MaxLoginAttempts}}","AUTH_TIMEOUT_SECONDS":"{{AuthTimeoutSeconds}}","DISABLE_RENDERING":"{{DisableRendering}}","ENABLE_MOD_INCOMPATIBLE_OPTIMIZATIONS":"{{EnableModIncompatibleOptimizations}}","FORCE_NEW_DEBUG_GAME":"{{ForceNewDebugGame}}","HEALTH_CHECK_SECONDS":"{{HealthCheckSeconds}}","VERBOSE_LOGGING":"{{VerboseLogging}}","STEAM_USERNAME":"{{SteamUsername}}","STEAM_PASSWORD":"{{SteamPassword}}","STEAM_REFRESH_TOKEN":"{{SteamRefreshToken}}"}
App.CommandLineParameterFormat=-{0} {1}
App.CommandLineParameterDelimiter=
App.ExitMethod=OS_CLOSE
App.ExitTimeout=30
App.ExitString=
App.ExitFile=app_exit.lck
App.HasWriteableConsole=False
App.HasReadableConsole=True
App.UDPLogger=False
App.SupportsLiveSettingsChanges=False
App.LiveSettingChangeCommandFormat=set {0} "{1}"
App.ForceIPBinding=False
App.SupportsIPv6=False
App.ApplicationIPBinding=0.0.0.0
App.Ports=@IncludeJson[stardew-privateports.json]
App.AdminPortRef=0
App.PrimaryApplicationPortRef=ApplicationPort1
App.UniversalSleepApplicationUDPPortRef=0
App.UniversalSleepSteamQueryPortRef=0
App.MaxUsers=10
App.UseRandomAdminPassword=False
App.PersistRandomPassword=False
App.RemoteAdminPassword=
App.AdminMethod=STDIO
App.IgnoreSTDOUTAfterRCON=False
App.LoginTransform=None
App.LoginTransformPrefix=
App.RCONConnectDelaySeconds=5
App.RCONConnectRetrySeconds=5
App.RCONHeartbeatMinutes=0
App.RCONHeartbeatCommand=ping
App.TelnetLoginFormat={0}
App.UpdateSources=[]
App.PreStartStages=[]
App.UserActions=[]
App.ForceUpdate=False
App.ForceUpdateReason=
App.Compatibility=None
App.SteamUpdateAnonymousLogin=True
App.SteamForceLoginPrompt=False
App.RapidStartup=False
App.SmartExcludeExemptions=["*.cfg","*.conf","*.config","*.ini","*.json","*.xml","*.properties","*.kvp","*.yml","*.yaml","*.toml","*.lua"]
App.SmartExcludeSupported=True
App.DumpFullChildProcessTree=True
App.MonitorChildProcessName=
App.MonitorDirectChildOnly=False
App.SupportsUniversalSleep=False
App.WakeupMode=Any
App.ApplicationReadyMode=Immediate
Console.FilterMatchRegex=
Console.FilterMatchReplacement=
Console.ThrowawayMessageRegex=
Console.AppReadyRegex=^$
Console.UserJoinRegex=^$
Console.UserLeaveRegex=^$
Console.UserChatRegex=^$
Console.UpdateAvailableRegex=^$
Console.MetricsRegex=
Console.SuppressLogAtStart=False
Console.ActivateLogRegex=
Console.UserActions={}
Limits.SleepMode=False
Limits.SleepOnStart=False
Limits.SleepDelayMinutes=5
Limits.DozeDelay=2
Limits.AutoRetryCount=2
Limits.SleepStartThresholdSeconds=25
